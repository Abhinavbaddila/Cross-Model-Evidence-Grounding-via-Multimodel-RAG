OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

MMRAG_TOP_K=6
MMRAG_FUSION_K=12
MMRAG_EMBED_BATCH=16
MMRAG_VISUAL_PROOFS=4
MMRAG_DETECTION_THRESHOLD=0.22

MMRAG_TEXT_EMBEDDING_MODEL=BAAI/bge-large-en-v1.5
MMRAG_IMAGE_EMBEDDING_MODEL=openai/clip-vit-base-patch32
MMRAG_RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
MMRAG_USE_RERANKER=1

MMRAG_VLM_PROVIDER=auto
MMRAG_VLM_MODEL=llava-hf/llava-v1.6-mistral-7b-hf
MMRAG_CAPTION_MODEL=Salesforce/blip-image-captioning-base
MMRAG_VQA_MODEL=Salesforce/blip-vqa-base
MMRAG_DETECTOR_PROVIDER=yolo
MMRAG_DETECTOR_MODEL=yolov8n.pt
MMRAG_DETECTOR_FALLBACK_MODEL=google/owlv2-base-patch16-ensemble

MMRAG_LLM_PROVIDER=extractive
MMRAG_LLAMA_MODEL=meta-llama/Llama-3.2-3B-Instruct
MMRAG_USE_OPENAI=1

